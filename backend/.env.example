# Скопируйте этот файл в .env и заполните своими данными
# cp .env.example .env

# === БАЗА ДАННЫХ ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=abozorcomfort
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# === JWT СЕКРЕТ (придумайте длинный случайный текст) ===
JWT_SECRET=zAp9!kLmN2xQrT7vBwYuS4hEjGdFcPoI

# === СЕРВЕР ===
PORT=3001

# === ПАРОЛЬ АДМИНИСТРАТОРА ===
# После первого запуска сервер создаст пользователя автоматически
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123

# === CORS (адрес вашего фронтенда) ===
# В разработке: http://localhost:3000
# На сервере: https://abozorcomfort.uz
FRONTEND_URL=http://localhost:3000
